{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-v2-schema/v2/schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "shell:default",
    "shell:allow-open",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/sherlock-cli",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/sherlock-cli",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}
